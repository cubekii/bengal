// Test file for integer and float type support
// Bengal uses i64 and f64 internally, but VM supports all C types for FFI

import std.io

// Test basic integer operations (uses i64)
let x = 42
let y = 10
println("x + y = ${x + y}")
println("x - y = ${x - y}")
println("x * y = ${x * y}")
println("x / y = ${x / y}")

// Test basic float operations (uses f64)
let a = 3.14
let b = 2.0
println("a + b = ${a + b}")
println("a * b = ${a * b}")

// Test mixed int/float operations
println("x + a = ${x + a}")

// Test integer comparison
if (x == 42) {
  println("x equals 42")
}

// Test float comparison
if (a > 3.0) {
  println("a is greater than 3")
}

// Test greater and less operators
if (x > y) {
  println("x is greater than y")
}

if (y < x) {
  println("y is less than x")
}

println("Type support test completed!")
