import std::io

fn fibonacci(n: int): int {
  let a = 0
  let b = 1

  // Check if n is less than 0
  if (n < 0) {
    println("Incorrect input")
  }

  // Check if n is equal to 0
  else if (n == 0) {
    return 0
  }

  // Check if n is equal to 1
  else if (n == 1) {
    return b
  } else {
    for (i in 1..n) {
      let c = a + b
      a = b
      b = c
    }
    return b
  }
}

println(str(fibonacci(9)))
