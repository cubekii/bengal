{
  "name": "Bengal",
  "scopeName": "source.bengal",
  "fileTypes": ["bl"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#types"
    },
    {
      "include": "#numbers"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.bengal",
          "match": "//.*$"
        },
        {
          "name": "comment.block.bengal",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.bengal",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.bengal",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.bengal",
          "match": "\\b(if|else|while|for|return|break|continue|match|fn|let|var|const|import|from|as|pub|struct|enum|trait|impl|use|mod|self|Self|true|false|null)\\b"
        },
        {
          "name": "keyword.operator.bengal",
          "match": "(\\+|-|\\*|/|%|=|==|!=|<|>|<=|>=|&&|\\|\\||!|&|\\||\\^|<<|>>|\\.|->|=>|::)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.bengal",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "entity.name.type.bengal",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "storage.type.bengal",
          "match": "\\b(i8|i16|i32|i64|i128|isize|u8|u16|u32|u64|u128|usize|f32|f64|bool|char|string|void|any)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.integer.bengal",
          "match": "\\b\\d+\\b"
        },
        {
          "name": "constant.numeric.float.bengal",
          "match": "\\b\\d+\\.\\d+\\b"
        }
      ]
    }
  }
}
