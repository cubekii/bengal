import std.io
import std.math

println("=== Math Constants ===")
println("PI: " + 3.14159265358)
println("E: " + 2.718281828459045)
println("TAU: " + 6.283185307179586)

println("\n=== Trigonometric Functions ===")
println("sin(0): " + math.sin(0.0))
println("sin(PI/2): " + math.sin(3.14159265358 / 2.0))
println("cos(0): " + math.cos(0.0))
println("cos(PI): " + math.cos(3.14159265358))
println("tan(0): " + math.tan(0.0))
println("tan(PI/4): " + math.tan(3.14159265358 / 4.0))
println("asin(1): " + math.asin(1.0))
println("acos(1): " + math.acos(1.0))
println("atan(1): " + math.atan(1.0))
println("atan2(1, 1): " + math.atan2(1.0, 1.0))

println("\n=== Hyperbolic Functions ===")
println("sinh(0): " + math.sinh(0.0))
println("cosh(0): " + math.cosh(0.0))
println("tanh(0): " + math.tanh(0.0))

println("\n=== Rounding Functions ===")
println("floor(3.7): " + math.floor(3.7))
println("ceil(3.2): " + math.ceil(3.2))
println("round(3.5): " + math.round(3.5))
println("trunc(3.9): " + math.trunc(3.9))
println("fract(3.7): " + math.fract(3.7))

println("\n=== Comparison Functions ===")
println("min(5.0, 3.0): " + math.min(5.0, 3.0))
println("max(5.0, 3.0): " + math.max(5.0, 3.0))
println("clamp(10.0, 0.0, 5.0): " + math.clamp(10.0, 0.0, 5.0))
println("abs(-5.5): " + math.abs(0.0 - 5.5))
println("sign(-5.5): " + math.sign(0.0 - 5.5))
println("sign(5.5): " + math.sign(5.5))
println("sign(0): " + math.sign(0.0))

println("\n=== Power and Root Functions ===")
println("sqrt(16): " + math.sqrt(16.0))
println("cbrt(27): " + math.cbrt(27.0))
println("pow(2, 10): " + math.pow(2.0, 10.0))
println("exp(1): " + math.exp(1.0))
println("ln(E): " + math.ln(2.718281828459045))
println("log10(100): " + math.log10(100.0))
println("log2(8): " + math.log2(8.0))
println("log(2, 8): " + math.log(2.0, 8.0))

println("\n=== Utility Functions ===")
println("hypot(3, 4): " + math.hypot(3.0, 4.0))
println("lerp(0, 10, 0.5): " + math.lerp(0.0, 10.0, 0.5))
println("step(5, 3): " + math.step(5.0, 3.0))
println("step(5, 7): " + math.step(5.0, 7.0))
println("smoothstep(0, 10, 5): " + math.smoothstep(0.0, 10.0, 5.0))

println("\n=== Angle Conversion ===")
println("toRadians(180): " + math.toRadians(180.0))
println("toDegrees(PI): " + math.toDegrees(3.14159265358))

println("\n=== All math tests passed! ===")
